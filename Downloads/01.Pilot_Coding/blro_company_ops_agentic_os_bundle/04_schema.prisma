generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum MemberRole { OWNER ADMIN EDITOR VIEWER }
enum AgentStatus { DRAFT ACTIVE DISABLED }
enum CustomerStatus { ACTIVE PROSPECT PARTNER HOLD LOST }
enum ProjectStatus { NEW_LEAD QUALIFICATION TECH_REVIEW PROPOSAL POC NEGOTIATION WON LOST HOLD }
enum OpportunityLevel { LOW MEDIUM HIGH }
enum ProductFamily { HCI HDR SCP SKE SASE NGAF IAG EPP NETWORK BACKUP VDI OTHER }
enum MailItemType { CUSTOMER_REQUEST TECH_QUESTION QUOTE_REQUEST SCHEDULE_REQUEST PARTNER_REQUEST SUPPORT_ISSUE INTERNAL UNKNOWN }
enum MailActionStatus { UNCLASSIFIED LINKED REPLY_DRAFTED WAITING_APPROVAL SENT NEEDS_REVIEW }
enum ReviewStatus { DRAFT IN_REVIEW NEEDS_VENDOR_CHECK CUSTOMER_REPLY_READY COMPLETED }
enum FeasibilityStatus { POSSIBLE NOT_POSSIBLE NEEDS_CONFIRMATION }
enum ProposalStatus { DRAFT INTERNAL_REVIEW WAITING_APPROVAL SENT ACCEPTED REJECTED EXPIRED }
enum WorkflowStatus { DRAFT ACTIVE PAUSED ERROR }
enum TriggerType { MANUAL SCHEDULE WEBHOOK EMAIL CALENDAR PROJECT_STATUS_CHANGE SHEET_CHANGE }
enum RunStatus { QUEUED RUNNING SUCCESS FAILED WAITING_APPROVAL CANCELED }
enum RiskLevel { LOW MEDIUM HIGH }
enum ApprovalStatus { PENDING APPROVED REJECTED CHANGES_REQUESTED EXPIRED }
enum ApprovalActionType { SEND_EMAIL SEND_MESSAGE UPDATE DELETE PUBLISH MOVE COST_ACTION SEND_QUOTE EXTERNAL_SHARE }
enum ConnectionProvider { SLACK NOTION GOOGLE_SHEETS GMAIL OUTLOOK GOOGLE_CALENDAR OUTLOOK_CALENDAR WEBHOOK }
enum ConnectionStatus { CONNECTED EXPIRED ERROR NOT_CONNECTED }
enum DocumentType { SOP BRAND_GUIDE FAQ PRODUCT_DOC REPORT PROPOSAL QUOTE MEETING_NOTE OTHER }

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  imageUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  memberships OrganizationMember[]
  runsStarted ExecutionRun[] @relation("RunStartedBy")
  approvalsRequested ApprovalItem[] @relation("ApprovalRequestedBy")
}

model Organization {
  id          String   @id @default(cuid())
  name        String
  description String?
  website     String?
  industry    String?
  defaultSignature String?
  mailStyleGuide String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  members      OrganizationMember[]
  customers    Customer[]
  projects     Project[]
  agents       Agent[]
  workflows    Workflow[]
  runs         ExecutionRun[]
  approvals    ApprovalItem[]
  connections  ToolConnection[]
  documents    KnowledgeDocument[]
  financeItems FinanceItem[]
}

model OrganizationMember {
  id             String     @id @default(cuid())
  organizationId String
  userId         String
  role           MemberRole @default(EDITOR)
  createdAt      DateTime   @default(now())
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  @@unique([organizationId, userId])
}

model Customer {
  id             String         @id @default(cuid())
  organizationId String
  name           String
  status         CustomerStatus @default(PROSPECT)
  industry       String?
  sizeLabel      String?
  website        String?
  notes          String?
  currentInfra   Json?
  productFit     ProductFamily[]
  opportunity    OpportunityLevel @default(MEDIUM)
  nextAction     String?
  nextActionDueAt DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts     Contact[]
  projects     Project[]
  mailItems    MailItem[]
  proposals    Proposal[]
  financeItems FinanceItem[]
  @@index([organizationId, name])
}

model Contact {
  id         String   @id @default(cuid())
  customerId String
  name       String
  email      String?
  phone      String?
  title      String?
  department String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Project {
  id             String        @id @default(cuid())
  organizationId String
  customerId     String?
  name           String
  productFamily  ProductFamily[]
  status         ProjectStatus @default(NEW_LEAD)
  opportunity    OpportunityLevel @default(MEDIUM)
  expectedRevenue Decimal?
  dueAt          DateTime?
  summary        String?
  nextAction     String?
  riskLevel      RiskLevel @default(MEDIUM)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?    @relation(fields: [customerId], references: [id])
  requests     ProjectRequest[]
  mailItems    MailItem[]
  presalesReviews PresalesReview[]
  proposals    Proposal[]
  tasks        Task[]
  runs         ExecutionRun[]
  approvals    ApprovalItem[]
  financeItems FinanceItem[]
  @@index([organizationId, status])
}

model ProjectRequest {
  id        String   @id @default(cuid())
  projectId String
  source    String?
  rawText   String
  extracted Json?
  requiredAction String?
  createdAt DateTime @default(now())
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model MailItem {
  id             String @id @default(cuid())
  organizationId String
  customerId     String?
  projectId      String?
  provider       ConnectionProvider
  externalMessageId String?
  threadKey      String?
  fromEmail      String?
  fromName       String?
  toEmails       String[]
  subject        String?
  snippet        String?
  bodyText       String?
  receivedAt     DateTime?
  type           MailItemType @default(UNKNOWN)
  actionStatus   MailActionStatus @default(UNCLASSIFIED)
  urgencyScore   Int?
  extracted      Json?
  replyDraft     String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer? @relation(fields: [customerId], references: [id])
  project      Project?  @relation(fields: [projectId], references: [id])
  runs         ExecutionRun[]
}

model PresalesReview {
  id             String @id @default(cuid())
  organizationId String
  projectId      String?
  title          String
  productFamily  ProductFamily[]
  status         ReviewStatus @default(DRAFT)
  feasibility    FeasibilityStatus @default(NEEDS_CONFIRMATION)
  requestSummary String?
  missingInfo    Json?
  checklist      Json?
  internalNotes  String?
  customerReplyDraft String?
  vendorQuestionDraft String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project      Project? @relation(fields: [projectId], references: [id])
}

model Proposal {
  id             String @id @default(cuid())
  organizationId String
  customerId     String?
  projectId      String?
  title          String
  status         ProposalStatus @default(DRAFT)
  productFamily  ProductFamily[]
  bom            Json?
  amount         Decimal?
  currency       String @default("KRW")
  customerSummary String?
  partnerRequestDraft String?
  validUntil     DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer? @relation(fields: [customerId], references: [id])
  project      Project?  @relation(fields: [projectId], references: [id])
  approvals    ApprovalItem[]
}

model Task {
  id        String   @id @default(cuid())
  projectId String?
  title     String
  description String?
  status    String @default("todo")
  priority  String @default("medium")
  dueAt     DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project Project? @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Agent {
  id             String      @id @default(cuid())
  organizationId String
  name           String
  department     String?
  roleTitle      String?
  description    String?
  personaPrompt  String?
  status         AgentStatus @default(DRAFT)
  goals          Json?
  allowedTools   String[]
  blockedActions String[]
  outputFormats  String[]
  approvalPolicy Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflows    Workflow[]
  runs         ExecutionRun[]
}

model Workflow {
  id             String @id @default(cuid())
  organizationId String
  agentId        String?
  name           String
  description    String?
  status         WorkflowStatus @default(DRAFT)
  triggerType    TriggerType
  triggerConfig  Json?
  steps          Json?
  approvalRule   Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agent        Agent? @relation(fields: [agentId], references: [id])
  runs         ExecutionRun[]
}

model ExecutionRun {
  id             String @id @default(cuid())
  organizationId String
  workflowId     String?
  agentId        String?
  projectId      String?
  mailItemId     String?
  startedById    String?
  title          String
  input          Json?
  plan           Json?
  output         Json?
  status         RunStatus @default(QUEUED)
  riskLevel      RiskLevel @default(LOW)
  errorMessage   String?
  startedAt      DateTime @default(now())
  completedAt    DateTime?
  createdAt      DateTime @default(now())
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  workflow     Workflow? @relation(fields: [workflowId], references: [id])
  agent        Agent? @relation(fields: [agentId], references: [id])
  project      Project? @relation(fields: [projectId], references: [id])
  mailItem     MailItem? @relation(fields: [mailItemId], references: [id])
  startedBy    User? @relation("RunStartedBy", fields: [startedById], references: [id])
  steps        RunStep[]
  approvals    ApprovalItem[]
}

model RunStep {
  id        String @id @default(cuid())
  runId     String
  name      String
  status    RunStatus
  input     Json?
  output    Json?
  error     String?
  startedAt DateTime @default(now())
  endedAt   DateTime?
  run ExecutionRun @relation(fields: [runId], references: [id], onDelete: Cascade)
}

model ApprovalItem {
  id             String @id @default(cuid())
  organizationId String
  runId          String?
  projectId      String?
  proposalId     String?
  requestedById  String?
  title          String
  summary        String?
  actionType     ApprovalActionType
  riskLevel      RiskLevel @default(MEDIUM)
  status         ApprovalStatus @default(PENDING)
  destination    String?
  preview        Json?
  warning        String?
  decidedAt      DateTime?
  decisionNote   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  run          ExecutionRun? @relation(fields: [runId], references: [id])
  project      Project? @relation(fields: [projectId], references: [id])
  proposal     Proposal? @relation(fields: [proposalId], references: [id])
  requestedBy  User? @relation("ApprovalRequestedBy", fields: [requestedById], references: [id])
}

model ToolConnection {
  id             String @id @default(cuid())
  organizationId String
  provider       ConnectionProvider
  status         ConnectionStatus @default(NOT_CONNECTED)
  accountLabel   String?
  scopes         String[]
  metadata       Json?
  connectedAt    DateTime?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  @@unique([organizationId, provider])
}

model KnowledgeDocument {
  id             String @id @default(cuid())
  organizationId String
  title          String
  type           DocumentType @default(OTHER)
  content        String?
  sourceUrl      String?
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
}

model FinanceItem {
  id             String @id @default(cuid())
  organizationId String
  customerId     String?
  projectId      String?
  type           String
  title          String
  amount         Decimal
  currency       String @default("KRW")
  expectedAt     DateTime?
  confirmedAt    DateTime?
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer? @relation(fields: [customerId], references: [id])
  project      Project?  @relation(fields: [projectId], references: [id])
}
